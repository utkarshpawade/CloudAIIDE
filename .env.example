# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local — it is already covered by .gitignore.
# ---------------------------------------------------------------------------

# Convex — from `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=

# Shared secret between the Next.js app and Convex internal actions.
# Generate one with: openssl rand -hex 32
# Set the same value in your Convex deployment env vars.
CLOUDAIIDE_CONVEX_INTERNAL_KEY=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# The Clerk JWT issuer domain, set in your Convex deployment env vars too.
CLERK_JWT_ISSUER_DOMAIN=

# AI provider — Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Inngest — https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Firecrawl — https://firecrawl.dev
FIRECRAWL_API_KEY=
